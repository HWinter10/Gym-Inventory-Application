<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!-- Login screen -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.LoginController"
      spacing="12"
      alignment="CENTER">

    <!-- Header -->
    <Label text="Inventory Manager" styleClass="screen-title" />

    <!-- Visual separation -->
    <Separator prefWidth="280" />

    <!-- Credentials input -->
    <!-- fx:id fields read by controller during authentication -->
    <TextField fx:id="usernameField"
               promptText="Username"
               prefWidth="260" />

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   prefWidth="260" />

    <!-- Triggers login logic -->
    <Button text="Login"
            onAction="#onLogin"
            prefWidth="260" />

    <!-- Displays validation or authentication errors -->
    <Label fx:id="messageLabel"
           styleClass="message"
           wrapText="true"
           visible="false"
           managed="false" />
</VBox>