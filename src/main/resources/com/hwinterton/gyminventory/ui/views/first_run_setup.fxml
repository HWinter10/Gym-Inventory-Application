<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<!-- First run setup screen -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.FirstRunSetupController"
      spacing="14"
      alignment="CENTER">

    <!-- Header -->
    <Label text="Initial Setup Complete" styleClass="screen-title" />
    <Label text="Record these credentials before continuing." wrapText="true" />

    <!-- Section divider -->
    <Separator prefWidth="500" />

    <!-- Temporary credentials -->
    <VBox spacing="12" alignment="CENTER" styleClass="panel" prefWidth="560" maxWidth="560">
        <Label text="Initial owner accounts" styleClass="section-title" />
        <Label fx:id="ownerLabel" wrapText="true" maxWidth="500" />
        <Label fx:id="backupLabel" wrapText="true" maxWidth="500" />
        <Label text="Both accounts will be required to change password at first sign-in." wrapText="true" maxWidth="500" />
    </VBox>

    <!-- Continue action -->
    <Button text="Continue to Login"
            onAction="#onContinue"
            prefWidth="220" />
</VBox>