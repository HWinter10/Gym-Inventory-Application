<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Main menu screen -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.MainController"
      spacing="18"
      alignment="TOP_CENTER">

    <!-- Header -->
    <Label text="Inventory Manager" styleClass="screen-title" />
    <Label text="Main Menu" styleClass="screen-subtitle" />

    <!-- User info panels -->
    <!-- fx:id values populated by controller after login -->
    <HBox spacing="16" alignment="CENTER">

        <!-- Logged-in user -->
        <VBox spacing="6"
              alignment="CENTER_LEFT"
              prefWidth="250"
              styleClass="sub-panel">
            <Label fx:id="welcomeLabel" text="Signed in as:" />
        </VBox>

        <!-- User role -->
        <VBox spacing="6"
              alignment="CENTER_LEFT"
              prefWidth="220"
              styleClass="sub-panel">
            <Label fx:id="roleLabel" text="Access level:" />
        </VBox>
    </HBox>

    <!-- Section divider -->
    <Separator prefWidth="820" />

    <!-- Spacer for layout balance -->
    <Region prefHeight="50" />

    <!-- Main action sections -->
    <HBox spacing="24" alignment="TOP_CENTER">

        <!-- Daily tasks -->
        <VBox spacing="12"
              alignment="TOP_CENTER"
              prefWidth="470"
              styleClass="panel">

            <Label text="Daily Tasks" styleClass="section-title" />
            <Separator prefWidth="380" />

            <!-- Navigation actions -->
            <Button fx:id="salesEntryButton"
                    text="Record Sale"
                    onAction="#onSalesEntry"
                    prefWidth="400" />

            <Button fx:id="inventoryAdjustmentButton"
                    text="Adjust Inventory"
                    onAction="#onInventoryAdjustment"
                    prefWidth="400" />

            <Button fx:id="reorderAlertsButton"
                    text="View Reorder Alerts"
                    onAction="#onReorderAlerts"
                    prefWidth="400" />
        </VBox>

        <!-- Administrative tools -->
        <VBox spacing="12"
              alignment="TOP_CENTER"
              prefWidth="260"
              styleClass="panel">

            <Label text="Administrative Tools" styleClass="section-title" />
            <Separator prefWidth="200" />

            <!-- Admin navigation -->
            <Button fx:id="manageProductsButton"
                    text="Manage Products"
                    onAction="#onManageProducts"
                    prefWidth="220" />

            <Button fx:id="manageUsersButton"
                    text="Manage Users"
                    onAction="#onManageUsers"
                    prefWidth="220" />

            <Button fx:id="actionLogButton"
                    text="View Action Logs"
                    onAction="#onActionLog"
                    prefWidth="220" />

            <!-- Divider before logout -->
            <Separator prefWidth="200" />

            <!-- Session control -->
            <Button text="Log Out"
                    onAction="#onLogout"
                    prefWidth="220" />
        </VBox>
    </HBox>
</VBox>