<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.ReorderAlertsController"
      spacing="12"
      alignment="CENTER"
      prefWidth="860"
      prefHeight="560">

    <Label text="Reorder Alerts" style="-fx-font-size: 18px;" />
    <Label text="Products at or below threshold" />

    <TableView fx:id="reorderTable" prefWidth="820" prefHeight="420">
        <columns>
            <TableColumn fx:id="colProductId" text="Product ID" prefWidth="90" />
            <TableColumn fx:id="colProductName" text="Product Name" prefWidth="240" />
            <TableColumn fx:id="colCategory" text="Category" prefWidth="160" />
            <TableColumn fx:id="colQuantityOnHand" text="Quantity On Hand" prefWidth="140" />
            <TableColumn fx:id="colReorderThreshold" text="Reorder Threshold" prefWidth="140" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Refresh" onAction="#onRefresh" />
        <Button text="Back" onAction="#onBack" />
    </HBox>

    <Label fx:id="messageLabel" wrapText="true" />
</VBox>