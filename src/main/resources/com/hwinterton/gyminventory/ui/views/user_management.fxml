<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- User management screen -->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hwinterton.gyminventory.ui.UserManagementController">

    <center>
        <VBox spacing="14" alignment="CENTER">

            <!-- Shared content column -->
            <VBox spacing="14" alignment="CENTER" styleClass="content-block">

                <!-- Header and status message -->
                <VBox spacing="10" alignment="CENTER" styleClass="panel content-block">
                    <Label text="Manage Users" styleClass="screen-title" />
                    <Label text="Create and manage user accounts (owner access only)" />
                    <Label fx:id="messageLabel"
                           styleClass="message"
                           wrapText="true"
                           visible="false"
                           managed="false"
                           maxWidth="500" />
                </VBox>

                <!-- User table -->
                <!-- Selected row used by controller to populate edit fields -->
                <TableView fx:id="userTable" prefHeight="280" prefWidth="860">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80" />
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="360" />
                        <TableColumn fx:id="colRole" text="Role" prefWidth="180" />
                        <TableColumn fx:id="colActive" text="Active" prefWidth="160" />
                    </columns>
                </TableView>

                <!-- Update and create sections -->
                <HBox spacing="16" alignment="TOP_CENTER" styleClass="dual-panel-row">

                    <!-- Update selected user -->
                    <VBox spacing="12"
                          alignment="CENTER"
                          prefWidth="422"
                          minWidth="422"
                          maxWidth="422"
                          styleClass="panel">
                        <Label text="Update Selected User" styleClass="section-title" />

                        <!-- Edit fields -->
                        <HBox spacing="10" alignment="CENTER">
                            <TextField fx:id="editUsernameField"
                                       promptText="Username"
                                       prefWidth="150" />
                            <ComboBox fx:id="editRoleCombo"
                                      promptText="Set role"
                                      prefWidth="150" />
                        </HBox>

                        <!-- User actions -->
                        <!-- Checkbox and buttons trigger controller updates -->
                        <HBox spacing="10" alignment="CENTER_LEFT" prefWidth="310" maxWidth="310">
                            <CheckBox fx:id="activeCheckBox"
                                      text="Active"
                                      onAction="#onToggleActive"
                                      prefWidth="70" />

                            <Button text="Reset Password"
                                    onAction="#onResetPassword"
                                    prefWidth="120"
                                    minWidth="120" />

                            <Button text="Update User"
                                    onAction="#onUpdateUser"
                                    prefWidth="120"
                                    minWidth="120" />
                        </HBox>
                    </VBox>

                    <!-- Create new user -->
                    <VBox spacing="12"
                          alignment="CENTER"
                          prefWidth="422"
                          minWidth="422"
                          maxWidth="422"
                          styleClass="panel">
                        <Label text="Create New User" styleClass="section-title" />

                        <!-- Input fields -->
                        <HBox spacing="10" alignment="CENTER">
                            <TextField fx:id="newUsernameField"
                                       promptText="Username"
                                       prefWidth="150" />
                            <ComboBox fx:id="newRoleCombo"
                                      promptText="Select role"
                                      prefWidth="150" />
                        </HBox>

                        <!-- Create action -->
                        <Button text="Create User"
                                onAction="#onCreateUser"
                                prefWidth="310" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <!-- Bottom actions -->
        <VBox spacing="8" alignment="CENTER" styleClass="action-bar">
            <Separator prefWidth="860" />
            <HBox spacing="12" alignment="CENTER">
                <Button text="Refresh List" onAction="#onRefresh" />
                <Button text="Back to Menu" onAction="#onBack" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>