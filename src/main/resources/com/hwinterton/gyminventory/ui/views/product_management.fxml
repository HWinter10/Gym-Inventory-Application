<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.ProductManagementController"
      spacing="10"
      alignment="CENTER"
      prefWidth="900"
      prefHeight="620">

    <Label text="Product Management" style="-fx-font-size: 18px;" />
    <Label text="Use this screen for product catalog setup. Use Inventory Adjustment and Sales Entry to change stock levels." wrapText="true" />

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="nameField" promptText="Product name" />
        <TextField fx:id="categoryField" promptText="Category" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="quantityField" promptText="Starting quantity for new product" />
        <TextField fx:id="reorderThresholdField" promptText="Reorder threshold" />
        <CheckBox fx:id="activeCheckBox" text="Active" selected="true" />
    </HBox>

    <Label fx:id="currentQuantityLabel" text="Current quantity on hand: n/a" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Create Product" onAction="#onCreateProduct" />
        <Button text="Update Selected Product" onAction="#onUpdateProduct" />
        <Button text="Clear Form" onAction="#onClearForm" />
        <Button text="Refresh" onAction="#onRefresh" />
        <Button text="Back" onAction="#onBack" />
    </HBox>

    <TableView fx:id="productTable" prefWidth="860" prefHeight="380">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70" />
            <TableColumn fx:id="colName" text="Name" prefWidth="220" />
            <TableColumn fx:id="colCategory" text="Category" prefWidth="180" />
            <TableColumn fx:id="colQuantity" text="Quantity On Hand" prefWidth="170" />
            <TableColumn fx:id="colReorderThreshold" text="Reorder Threshold" prefWidth="170" />
            <TableColumn fx:id="colActive" text="Active" prefWidth="90" />
        </columns>
    </TableView>

    <Label fx:id="messageLabel" wrapText="true" />
</VBox>
