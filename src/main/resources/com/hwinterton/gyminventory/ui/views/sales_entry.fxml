<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.SalesEntryController"
      spacing="14"
      alignment="CENTER"
      prefWidth="700"
      prefHeight="420">

    <Label text="Sales Entry" style="-fx-font-size: 18px;" />
    <Label text="Quick daily product sale recording" />

    <HBox spacing="10" alignment="CENTER">
        <Label text="Category:" />
        <ComboBox fx:id="categoryComboBox" prefWidth="220" promptText="Select category" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Product:" />
        <ComboBox fx:id="productComboBox" prefWidth="300" promptText="Select product" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Quantity sold:" />
        <TextField fx:id="quantityField" prefWidth="120" promptText="Enter quantity" />
    </HBox>

    <Label fx:id="availableQuantityLabel" text="Available quantity: " />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Submit Sale" onAction="#onSubmitSale" />
        <Button text="Clear" onAction="#onClear" />
        <Button text="Back" onAction="#onBack" />
    </HBox>

    <Label fx:id="messageLabel" wrapText="true" />
</VBox>