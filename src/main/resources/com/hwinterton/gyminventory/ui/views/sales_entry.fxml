<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Sales entry screen -->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hwinterton.gyminventory.ui.SalesEntryController">

    <top>
        <!-- Header and form -->
        <VBox spacing="10" alignment="CENTER" styleClass="panel">
            <Label text="Record Sale" styleClass="screen-title" />
            <Label text="Enter product and quantity to record a sale" />

            <!-- Status message -->
            <Label fx:id="messageLabel"
                   styleClass="message"
                   wrapText="true"
                   visible="false"
                   managed="false"
                   maxWidth="500" />

            <Separator prefWidth="700" />

            <!-- Sale inputs -->
            <!-- Category selection filters available products -->
            <VBox spacing="12" alignment="CENTER" styleClass="form-block">

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Category:" minWidth="110" />
                    <ComboBox fx:id="categoryComboBox"
                              prefWidth="260"
                              promptText="Select category" />
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Product:" minWidth="110" />
                    <ComboBox fx:id="productComboBox"
                              prefWidth="260"
                              promptText="Select product" />
                </HBox>

                <!-- Quantity used by controller to update inventory -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Quantity:" minWidth="110" />
                    <TextField fx:id="quantityField"
                               prefWidth="260"
                               promptText="Enter quantity" />
                </HBox>
            </VBox>

            <!-- Current stock display -->
            <!-- Updated when product selection changes -->
            <VBox spacing="6"
                  alignment="CENTER"
                  styleClass="sub-panel form-block">
                <Label text="Available Stock" styleClass="section-title" />
                <Label fx:id="availableQuantityLabel" text="0" />
            </VBox>
        </VBox>
    </top>

    <bottom>
        <!-- Bottom actions -->
        <VBox spacing="8" alignment="CENTER" styleClass="action-bar">
            <Separator />

            <HBox spacing="12" alignment="CENTER">
                <Button text="Submit Sale" onAction="#onSubmitSale" />
                <Button text="Clear Form" onAction="#onClear" />
                <Button text="Back to Menu" onAction="#onBack" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>