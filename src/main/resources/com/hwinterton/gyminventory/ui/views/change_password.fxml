<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<!-- Change password screen -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.ChangePasswordController"
      spacing="12"
      alignment="CENTER">

    <!-- Header -->
    <Label text="Change Password" styleClass="screen-title" />
    <Label text="You must change your password before continuing." wrapText="true" />

    <!-- Visual separation between header and form -->
    <Separator prefWidth="300" />

    <!-- Password inputs -->
    <!-- fx:id connects fields to controller -->
    <PasswordField fx:id="currentPasswordField"
                   promptText="Current password"
                   prefWidth="280" />

    <PasswordField fx:id="newPasswordField"
                   promptText="New password (8+ chars)"
                   prefWidth="280" />

    <PasswordField fx:id="confirmPasswordField"
                   promptText="Confirm new password"
                   prefWidth="280" />

    <!-- Triggers controller logic -->
    <Button text="Update Password"
            onAction="#onUpdatePassword"
            prefWidth="280" />

    <!-- Displays validation or success message -->
    <Label fx:id="messageLabel"
           styleClass="message"
           wrapText="true" />
</VBox>