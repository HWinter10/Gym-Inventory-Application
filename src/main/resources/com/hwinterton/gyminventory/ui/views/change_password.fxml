<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.ChangePasswordController"
      spacing="12"
      alignment="CENTER"
      prefWidth="520"
      prefHeight="320">

    <Label text="Change Password" style="-fx-font-size: 18px;" />
    <Label text="You must change your password before continuing." />

    <PasswordField fx:id="currentPasswordField" promptText="Current password" />
    <PasswordField fx:id="newPasswordField" promptText="New password (8+ chars)" />
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" />

    <Button text="Update Password" onAction="#onUpdatePassword" />

    <Label fx:id="messageLabel" />
</VBox>