<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Inventory adjustment screen -->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hwinterton.gyminventory.ui.InventoryAdjustmentController">

    <top>
        <!-- Main content -->
        <VBox spacing="10" alignment="CENTER" styleClass="panel">

            <!-- Header and status message -->
            <Label text="Adjust Inventory" styleClass="screen-title" />
            <Label text="Record stock changes with a required reason" />
            <Label fx:id="messageLabel"
                   styleClass="message"
                   wrapText="true"
                   visible="false"
                   managed="false"
                   maxWidth="500" />

            <!-- Form section -->
            <Separator prefWidth="720" />
            <Label text="Adjustment Details" styleClass="section-title" />

            <!-- Form fields -->
            <VBox spacing="10" alignment="CENTER" styleClass="form-block">
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Category:" minWidth="110" />
                    <ComboBox fx:id="categoryComboBox"
                              prefWidth="260"
                              promptText="Select category" />
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Product:" minWidth="110" />
                    <ComboBox fx:id="productComboBox"
                              prefWidth="260"
                              promptText="Select product" />
                </HBox>

                <!-- Adjustment inputs -->
                <!-- ComboBoxes and fields read by controller during submit -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Direction:" minWidth="110" />
                    <ComboBox fx:id="directionComboBox"
                              prefWidth="260"
                              promptText="Select type" />
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Amount:" minWidth="110" />
                    <TextField fx:id="amountField"
                               prefWidth="260"
                               promptText="Enter amount" />
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Reason:" minWidth="110" />
                    <ComboBox fx:id="reasonComboBox"
                              prefWidth="260"
                              promptText="Select reason" />
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Notes (optional):" minWidth="110" />
                    <TextArea fx:id="notesArea"
                              prefWidth="260"
                              prefHeight="60"
                              wrapText="true"
                              promptText="Optional notes" />
                </HBox>
            </VBox>

            <!-- Current stock display -->
            <VBox spacing="6"
                  alignment="CENTER"
                  styleClass="sub-panel form-block">
                <Label text="Available Stock" styleClass="section-title" />
                <Label fx:id="availableQuantityLabel" text="0" />
            </VBox>
        </VBox>
    </top>

    <bottom>
        <!-- Bottom actions -->
        <VBox spacing="8" alignment="CENTER" styleClass="action-bar">
            <Separator />

            <HBox spacing="12" alignment="CENTER">
                <!-- Form actions -->
                <Button text="Submit Adjustment" onAction="#onSubmitAdjustment" />
                <Button text="Clear Form" onAction="#onClear" />
                <Button text="Back to Menu" onAction="#onBack" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>