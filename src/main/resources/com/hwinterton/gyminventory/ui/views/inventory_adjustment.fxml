<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hwinterton.gyminventory.ui.InventoryAdjustmentController"
      spacing="14"
      alignment="CENTER"
      prefWidth="760"
      prefHeight="520">

    <Label text="Inventory Adjustment" style="-fx-font-size: 18px;" />
    <Label text="Record stock changes with required reason codes" />

    <HBox spacing="10" alignment="CENTER">
        <Label text="Category:" />
        <ComboBox fx:id="categoryComboBox" prefWidth="220" promptText="Select category" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Product:" />
        <ComboBox fx:id="productComboBox" prefWidth="320" promptText="Select product" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Direction:" />
        <ComboBox fx:id="directionComboBox" prefWidth="140" promptText="Select direction" />

        <Label text="Amount:" />
        <TextField fx:id="amountField" prefWidth="120" promptText="Enter amount" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Reason:" />
        <ComboBox fx:id="reasonComboBox" prefWidth="220" promptText="Select reason code" />
    </HBox>

    <VBox spacing="6" alignment="CENTER">
        <Label text="Notes:" />
        <TextArea fx:id="notesArea" prefWidth="520" prefHeight="120" wrapText="true" promptText="Optional notes" />
    </VBox>

    <Label fx:id="availableQuantityLabel" text="Available quantity: " />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Submit Adjustment" onAction="#onSubmitAdjustment" />
        <Button text="Clear" onAction="#onClear" />
        <Button text="Back" onAction="#onBack" />
    </HBox>

    <Label fx:id="messageLabel" wrapText="true" />
</VBox>